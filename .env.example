# Copy to .env and fill in. NEVER commit .env.
# Constants below are GOAT mainnet — same for everyone on the team.

# --- GOAT mainnet (constants — don't change) ---
GOAT_RPC_URL=https://rpc.goat.network
GOAT_CHAIN_ID=2345
GOAT_EXPLORER_URL=https://explorer.goat.network
ERC8004_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
USDC_ADDRESS=0x3022b87ac063DE95b1570F46f5e470F8B53112D8

# --- Agent identity (generated per dev; SHARED across team only for the demo wallet) ---
# Generate via your agent: "Create a wallet and output 1) the private key 2) the wallet address"
# Request gas via the form linked in CLAUDE.md after generating
AGENT_PRIVATE_KEY=
AGENT_ADDRESS=
AGENT_NAME=
AGENT_URI=                # public Gist URL (raw) with agent metadata JSON

# --- x402 merchant (from https://x402-merchant.goat.network/) ---
GOATX402_API_URL=
GOATX402_API_KEY=
GOATX402_API_SECRET=
GOATX402_MERCHANT_ID=
GOATX402_RECEIVING_WALLET=

# --- Notification sinks ---
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Demo target ---
DEMO_TARGET_URL=http://localhost:3000
DEMO_SCOPE_GRANT_ID=

# --- Scanner config ---
NUCLEI_TEMPLATES_PATH=
SCAN_INTERVAL_SECONDS=300
