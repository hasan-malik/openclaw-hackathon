# Copy to .env and fill in secrets. NEVER commit .env.
# GOAT mainnet constants are pre-filled — do not change them.

# --- LLM (Anthropic Claude — powers agent chat + tool use) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- GOAT mainnet (constants — same for everyone) ---
GOAT_RPC_URL=https://rpc.goat.network
GOAT_CHAIN_ID=2345
GOAT_EXPLORER_URL=https://explorer.goat.network
ERC8004_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
USDC_ADDRESS=0x3022b87ac063DE95b1570F46f5e470F8B53112D8

# --- Agent identity (generated per dev; SHARED across team only for the demo wallet) ---
# Generate via `pnpm wallet`
AGENT_PRIVATE_KEY=
AGENT_ADDRESS=
AGENT_NAME=shieldclaw_demo
AGENT_VERSION=1.0.0
AGENT_CAPABILITIES=sql_injection_testing,port_scanning,ssl_analysis,credential_exposure
AGENT_URI=                # public Gist URL (raw) with agent metadata JSON
AGENT_ID=                 # populated after `pnpm register`

# --- x402 merchant (from https://x402-merchant.goat.network/) ---
GOATX402_API_URL=https://x402-api.goat.network
GOATX402_API_KEY=
GOATX402_API_SECRET=
GOATX402_MERCHANT_ID=
GOATX402_RECEIVING_WALLET=
X402_PRICE_PER_VULNERABILITY_USDC=10

# --- Notification sinks ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=             # numeric chat ID; add @userinfobot to channel to get it
SLACK_WEBHOOK_URL=

# Public URL of the dashboard (used by Telegram bot to deep-link findings).
# Leave as localhost during dev; replace with your Vercel URL after deploying.
DASHBOARD_URL=http://localhost:3000

# --- Demo target ---
DEMO_TARGET_URL=http://localhost:3001
DEMO_SCOPE_GRANT_ID=
DEMO_MODE=true                # compresses timeouts for live demo

# --- Scanner config ---
NUCLEI_TEMPLATES_PATH=
SCAN_INTERVAL_SECONDS=300
