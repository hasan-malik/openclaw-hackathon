# Copy to .env and fill in secrets. NEVER commit .env.
# GOAT mainnet constants are pre-filled — do not change them.

# --- LLM ---
ANTHROPIC_API_KEY=

# --- GOAT mainnet (constants — same for everyone) ---
GOAT_RPC_URL=https://rpc.goat.network
GOAT_CHAIN_ID=2345
GOAT_EXPLORER_URL=https://explorer.goat.network
ERC8004_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
USDC_ADDRESS=0x3022b87ac063DE95b1570F46f5e470F8B53112D8

# --- Agent wallet (generated per team; shared only for the live demo wallet) ---
# Generate: ask the GOAT mentor, or use AgentKit wallet creation script
AGENT_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=
AGENT_NAME=ShieldClaw Security Agent
AGENT_VERSION=1.0.0
AGENT_CAPABILITIES=sql_injection_testing,port_scanning,ssl_analysis
AGENT_URI=           # public Gist URL (raw JSON) with agent metadata — needed for ERC-8004

# --- x402 merchant (from https://x402-merchant.goat.network/) ---
GOATX402_API_URL=
GOATX402_API_KEY=
GOATX402_API_SECRET=
GOATX402_MERCHANT_ID=
GOATX402_RECEIVING_WALLET=
X402_PRICE_PER_VULNERABILITY_USDC=10

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=   # number like -1001234567890; add @userinfobot to channel to get it

# --- Demo target ---
TARGET_URL=http://localhost:3001

# --- Demo mode (compresses timeouts for live demo) ---
DEMO_MODE=true
